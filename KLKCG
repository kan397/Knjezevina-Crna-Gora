<!DOCTYPE html>
<html lang="sr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Košarkaški Savez Kneževine Crne Gore</title>

<style>
*{
box-sizing:border-box;
}

body{
margin:0;
font-family:Arial, sans-serif;
background:#eeeeee;
overflow-x:hidden;
}

.header{
background:#a00000;
color:white;
text-align:center;
padding:25px 10px;
}

.grb{
font-size:60px;
}

.header h1{
margin:5px;
font-size:30px;
}

.menu{
background:#222;
display:flex;
justify-content:center;
gap:25px;
padding:15px;
flex-wrap:wrap;
}

.menu a{
color:white;
text-decoration:none;
font-weight:bold;
}

.banner{
width:95%;
max-width:1100px;
margin:20px auto;
background:linear-gradient(90deg,#900000,#d4af37);
color:white;
padding:40px 15px;
text-align:center;
border-radius:12px;
}

.container{
width:95%;
max-width:1100px;
margin:auto;
}

.box{
background:white;
margin:20px 0;
padding:20px;
border-radius:12px;
box-shadow:0 2px 8px #ccc;
}

h2{
color:#900000;
border-bottom:3px solid #d4af37;
padding-bottom:8px;
}

.news{
display:flex;
gap:15px;
flex-wrap:wrap;
}

.card{
flex:1;
min-width:220px;
background:#f5f5f5;
padding:15px;
border-radius:10px;
}

table{
width:100%;
border-collapse:collapse;
}

th{
background:#900000;
color:white;
}

td,th{
padding:12px;
text-align:center;
border-bottom:1px solid #ddd;
}

.clubovi{
display:flex;
gap:15px;
flex-wrap:wrap;
}

.klub{
background:#900000;
color:white;
padding:15px;
border-radius:10px;
flex:1;
min-width:150px;
text-align:center;
}

.footer{
background:#222;
color:white;
text-align:center;
padding:20px;
margin-top:30px;
}
</style>

</head>

<body>

<header class="header">

<div class="grb">🏀</div>

<h1>Košarkaški Savez<br>
Kneževine Crne Gore</h1>

<p>Zvanična stranica prvenstva</p>

</header>


<nav class="menu">

